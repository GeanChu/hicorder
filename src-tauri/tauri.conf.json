{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hicorder",
  "version": "0.2.0",
  "identifier": "com.hicapital.hicorder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hicorder",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/recordings/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "hi.capital",
    "copyright": "Copyright (c) 2026 hi.capital",
    "category": "Productivity",
    "shortDescription": "Gravador de reunioes com transcricao por IA",
    "longDescription": "Hicorder grava o audio do microfone e do sistema durante reunioes, transcreve com IA, gera resumos e envia notas para o CRM. Codigo aberto (MIT).",
    "homepage": "https://github.com/GeanChu/hicorder",
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
